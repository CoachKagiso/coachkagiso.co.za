ZOHO_ACCOUNTS_BASE_URL=https://accounts.zoho.com
ZOHO_MAIL_BASE_URL=https://mail.zoho.com/api
ZOHO_AUTH_REDIRECT_URI=https://coachkagiso.co.za/api/auth/zoho/callback
# Optional if you want to skip account/folder discovery on each sync.
ZOHO_MAIL_ACCOUNT_ID=
ZOHO_MAIL_INBOX_FOLDER_ID=

